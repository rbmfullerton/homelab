{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "description": "Matches standard image/image_version pairs",
      "customType": "regex",
      "fileMatch": ["(^|/)variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"image\"\\s+{[^}]*?default\\s+=\\s+\"(?<depName>[^\"]+)\"[^}]*?}\\s+variable\\s+\"image_version\"\\s+{[^}]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker"
    },
    {
      "description": "Matches image2/image_version2",
      "customType": "regex",
      "fileMatch": ["(^|/)variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"image2\"\\s+{[^}]*?default\\s+=\\s+\"(?<depName>[^\"]+)\"[^}]*?}\\s+variable\\s+\"image_version2\"\\s+{[^}]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker"
    },
    {
      "description": "Matches Helm repo, chart, and ver variables",
      "customType": "regex",
      "fileMatch": ["(^|/)variables\\.tf$"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "variable\\s+\"repo\"\\s+{[^}]*?default\\s+=\\s+\"(?<registryUrl>[^\"]+)\"",
        "variable\\s+\"chart\"\\s+{[^}]*?default\\s+=\\s+\"(?<depName>[^\"]+)\"",
        "variable\\s+\"ver\"\\s+{[^}]*?default\\s+=\\s+\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "helm"
    },
    {
      "description": "Matches inline container images in .tf files",
      "customType": "regex",
      "fileMatch": ["\\.tf$"],
      "matchStrings": [
        "image\\s+=\\s+\"(?<depName>[^:]+):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Universal Docker logic",
      "matchDatasources": ["docker"],
      "versioning": "docker"
    },
    {
      "description": "Radarr: Handle 'version-' with 4-part versioning (e.g., 6.0.4.10291)",
      "matchPackageNames": ["lscr.io/linuxserver/radarr"],
      "versioning": "regex:^(?<compatibility>version-)(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$"
    },
    {
      "description": "Bookshelf: Handle 'hardcover-v' with 4-part versioning (e.g., 0.4.20.127)",
      "matchPackageNames": ["ghcr.io/pennydreadful/bookshelf"],
      "versioning": "regex:^(?<compatibility>.*-v)(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$"
    },
    {
      "description": "CUDA date-based versioning for ComfyUI",
      "matchPackageNames": ["mmartial/comfyui-nvidia-docker"],
      "versioning": "regex:^(?<compatibility>ubuntu24_cuda12\\.6\\.3-)(?<major>\\d{4})(?<minor>\\d{2})(?<patch>\\d{2})$"
    }
  ]
}
